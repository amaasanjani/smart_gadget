# ========================
# Frontend .gitignore
# React + Vite
# ========================

# ── Dependencies ─────────────────────────────────
node_modules/

# ── Build Output ─────────────────────────────────
dist/
dist-ssr/

# ── Environment ──────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Vite Cache ───────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── Logs ─────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing / Coverage ───────────────────────────
coverage/

# ── OS Files ─────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors / IDEs ───────────────────────────────
.vscode/
.idea/
*.suo
*.sw?
