# ========================
# Root .gitignore
# smart_gadget monorepo
# ========================

# ── Node ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js

# ── Environment / Secrets ────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Build Outputs ────────────────────────────────
dist/
build/
out/

# ── Uploaded Files (multer) ───────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ─────────────────────────────────────────
logs/
*.log

# ── OS Files ─────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors / IDEs ───────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ─────────────────────────────────────────
*.tgz
*.zip
coverage/
.cache/
